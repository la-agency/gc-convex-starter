{
	"$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true
	},
	"files": {
		"includes": ["**", "!convex/_generated", "!!.next", "!!out", "!!build"]
	},
	"linter": {
		"rules": {
			"recommended": true,
			"a11y": "off",
			"security": {
				"noDangerouslySetInnerHtml": "off"
			}
		}
	},
	"css": {
		"parser": {
			"tailwindDirectives": true
		}
	},
	"assist": {
		"actions": {
			"source": {
				"organizeImports": "on"
			}
		}
	}
}
